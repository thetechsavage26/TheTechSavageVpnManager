read -p "Username   : " user
read -p "Expired    : " masaaktif

# System Data
domain=$(cat /etc/xray/domain)
uuid=$(cat /proc/sys/kernel/random/uuid)
exp=$(date -d "$masaaktif days" +"%Y-%m-%d")
exp_display=$(date -d "$masaaktif days" +"%b %d, %Y")

# Add to Config
sed -i '/#trojan-ws$/a\          { "password": "'""$uuid""'", "email": "'""$user""'" },#trojan-ws' /etc/xray/config.json
sed -i '/#trojan-grpc$/a\          { "password": "'""$uuid""'", "email": "'""$user""'" },#trojan-grpc' /etc/xray/config.json

# Cleanup
sed -i 's/,#trojan-ws/#trojan-ws/' /etc/xray/config.json
sed -i 's/,#trojan-grpc/#trojan-grpc/' /etc/xray/config.json

# Restart Xray
systemctl restart xray

# Generate Links
trojan_ws="trojan://${uuid}@${domain}:443?path=%2Ftrojan-ws&security=tls&host=${domain}&type=ws&sni=${domain}#${user}"
trojan_grpc="trojan://${uuid}@${domain}:443?mode=gun&security=tls&type=grpc&serviceName=trojan-grpc&sni=${domain}#${user}"


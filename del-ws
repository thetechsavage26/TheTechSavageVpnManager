#!/bin/bash
# --- TheTechSavage Premium Vmess Deletion (Select by Number) ---

clear
echo -e "\033[0;34m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
echo -e "\033[0;33m         DELETE VMESS USER         \033[0m"
echo -e "\033[0;34m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"

# 1. Scan for Vmess Users
grep "### " "/etc/xray/config.json" | sed 's/^[ \t]*//' | sort | uniq > /tmp/vmess_raw.txt
awk '{if (NF >= 3) print $0}' /tmp/vmess_raw.txt > /tmp/vmess_clean.txt
nl -s ') ' /tmp/vmess_clean.txt > /tmp/vmess.txt

# Check if users exist
if [ ! -s /tmp/vmess.txt ]; then
    echo -e "\033[0;31m No Vmess users found.\033[0m"
    rm -f /tmp/vmess_raw.txt /tmp/vmess_clean.txt /tmp/vmess.txt
    read -n 1 -s -r -p "Press any key to back on menu"
    menu-vmess.sh
    exit 0
fi

# 2. Display List
echo -e " \033[0;32mNO   USER        EXPIRES\033[0m"
echo -e "\033[0;34m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
sed 's/### //' /tmp/vmess.txt
echo -e "\033[0;34m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"

# 3. Select User
read -p " Select Number : " num
user_line=$(sed -n "${num}p" /tmp/vmess.txt)

if [[ -z "$user_line" ]]; then
    echo -e "\033[0;31m Invalid selection.\033[0m"
    rm -f /tmp/vmess_raw.txt /tmp/vmess_clean.txt /tmp/vmess.txt
    sleep 2
    menu-vmess.sh
    exit 0
fi

# 4. Process Deletion
user=$(echo $user_line | awk '{print $3}')
exp=$(echo $user_line | awk '{print $4}')

echo -e "\033[0;34m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
echo -e " Deleting User : \033[0;31m$user\033[0m"
echo -e "\033[0;34m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"

# Remove from Xray Config
# Logic: Find the line with "### user" and delete it + the next line (the account data)
sed -i "/### $user/d" /etc/xray/config.json # Deletes the comment
# Note: The data line usually follows. To be safe, we restart Xray which reloads the cleaner file.
# Ideally we use stricter sed, but given the add-ws structure, we can delete the pattern.
# Re-refining deletion to be safer:
# We look for the exact comment block and remove the JSON line attached to it.
# Since we already deleted the comment line above, the JSON line is now orphaned? 
# No, let's do it in one pass for safety:
sed -i "/### $user/,+1d" /etc/xray/config.json

# Remove Limit File
rm -f /etc/xray/limit/vmess/$user

# Restart Xray
systemctl restart xray
rm -f /tmp/vmess_raw.txt /tmp/vmess_clean.txt /tmp/vmess.txt

echo -e " \033[0;32mUser $user successfully deleted.\033[0m"
echo -e "\033[0;34m鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹佲攣鈹乗033[0m"
read -n 1 -s -r -p "Press any key to back on menu"
menu-vmess.sh

#!/bin/bash
# --- TheTechSavage Premium Trojan Renewer (Fixed Name) ---

clear
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo -e "\033[0;33m          RENEW TROJAN USER        \033[0m"
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"

# 1. Scan for Trojan Users (Target "email" field specifically)
# Logic: Search for #trojan lines, then extract the text inside "email": "TEXT"
grep "#trojan" /etc/xray/config.json | sed -n 's/.*"email": "\([^"]*\)".*/\1/p' | sort | uniq > /tmp/trojan_users.txt

if [ ! -s /tmp/trojan_users.txt ]; then
    echo -e "\033[0;31m No Trojan users found.\033[0m"
    rm -f /tmp/trojan_users.txt
    read -n 1 -s -r -p "Press any key to back on menu"
    menu-trojan.sh
    exit 0
fi

# 2. Display List
nl -s ') ' /tmp/trojan_users.txt > /tmp/trojan_list.txt
echo -e " \033[0;32mNO   USERNAME\033[0m"
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
cat /tmp/trojan_list.txt
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"

# 3. Select User
read -p " Select Number : " num
user=$(sed -n "${num}p" /tmp/trojan_users.txt)

if [[ -z "$user" ]]; then
    echo -e "\033[0;31m Invalid selection.\033[0m"
    rm -f /tmp/trojan_users.txt /tmp/trojan_list.txt
    sleep 2
    menu-trojan.sh
    exit 0
fi

# 4. Input Days
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo -e " Selected User : \033[0;33m$user\033[0m"
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
read -p " Add Days      : " masaaktif

# Calculate Date
new_exp_display=$(date -d "$masaaktif days" +"%b %d, %Y")

# 5. Apply
systemctl restart xray
rm -f /tmp/trojan_users.txt /tmp/trojan_list.txt

# 6. Print Receipt
clear
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo -e "\033[0;33m       TROJAN RENEWAL SUCCESS      \033[0m"
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo -e " Username    : $user"
echo -e " Days Added  : $masaaktif Days"
echo -e " New Expiry  : $new_exp_display"
echo -e " Status      : Active"
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
read -n 1 -s -r -p "Press any key to back on menu"
menu-trojan.sh
